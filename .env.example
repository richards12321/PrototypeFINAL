# Local development config. On Streamlit Cloud, set these in the app's
# secrets TOML instead. Copy this file to .env and fill in your values.
#
# Azure endpoint, deployment names, and API version are now hard-coded
# in assessment_logic/llm_client.py — you only need the API key here.

# Azure OpenAI API key for the Capgemini capstone resource.
AZURE_OPENAI_API_KEY=your-azure-key-here

# Recruiter dashboard login password.
RECRUITER_PASSWORD=changeme-local-dev
